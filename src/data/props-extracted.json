{
  "button": [
    {
      "name": "variant",
      "type": "enum",
      "defaultValue": "primary",
      "required": false,
      "description": "Visual style variant of the button",
      "enumValues": [
        "primary",
        "secondary",
        "outline",
        "ghost"
      ]
    },
    {
      "name": "size",
      "type": "enum",
      "defaultValue": "md",
      "required": false,
      "description": "Size of the button",
      "enumValues": [
        "sm",
        "md",
        "lg"
      ]
    },
    {
      "name": "disabled",
      "type": "boolean",
      "defaultValue": "false",
      "required": false,
      "description": "Whether the button is disabled"
    },
    {
      "name": "loading",
      "type": "boolean",
      "defaultValue": "false",
      "required": false,
      "description": "Whether the button is in a loading state"
    },
    {
      "name": "children",
      "type": "ReactNode",
      "required": true,
      "description": "Content displayed inside the button"
    },
    {
      "name": "onClick",
      "type": "() => void",
      "required": false,
      "description": "Click handler"
    },
    {
      "name": "fullWidth",
      "type": "boolean",
      "defaultValue": "false",
      "required": false,
      "description": "Whether the button spans the full width of its container"
    }
  ],
  "input": [
    {
      "name": "value",
      "type": "string",
      "required": true,
      "description": "Current value of the input"
    },
    {
      "name": "onChange",
      "type": "(value: string) => void",
      "required": true,
      "description": "Callback fired when the input value changes"
    },
    {
      "name": "placeholder",
      "type": "string",
      "defaultValue": "",
      "required": false,
      "description": "Placeholder text shown when the input is empty"
    },
    {
      "name": "label",
      "type": "string",
      "required": false,
      "description": "Label text displayed above the input"
    },
    {
      "name": "error",
      "type": "string",
      "required": false,
      "description": "Error message displayed below the input"
    },
    {
      "name": "disabled",
      "type": "boolean",
      "defaultValue": "false",
      "required": false,
      "description": "Whether the input is disabled"
    },
    {
      "name": "size",
      "type": "enum",
      "defaultValue": "md",
      "required": false,
      "description": "Size of the input field",
      "enumValues": [
        "sm",
        "md",
        "lg"
      ]
    },
    {
      "name": "type",
      "type": "enum",
      "defaultValue": "text",
      "required": false,
      "description": "HTML input type",
      "enumValues": [
        "number",
        "text",
        "password",
        "email"
      ]
    }
  ],
  "card": [
    {
      "name": "title",
      "type": "string",
      "required": true,
      "description": "Title displayed at the top of the card"
    },
    {
      "name": "description",
      "type": "string",
      "required": false,
      "description": "Short description displayed below the title"
    },
    {
      "name": "imageUrl",
      "type": "string",
      "required": false,
      "description": "URL of an image displayed at the top of the card"
    },
    {
      "name": "variant",
      "type": "enum",
      "defaultValue": "default",
      "required": false,
      "description": "Visual style variant of the card",
      "enumValues": [
        "default",
        "bordered",
        "elevated"
      ]
    },
    {
      "name": "padding",
      "type": "enum",
      "defaultValue": "md",
      "required": false,
      "description": "Internal padding of the card",
      "enumValues": [
        "none",
        "sm",
        "md",
        "lg"
      ]
    },
    {
      "name": "hoverable",
      "type": "boolean",
      "defaultValue": "false",
      "required": false,
      "description": "Whether the card has a hover lift effect"
    },
    {
      "name": "children",
      "type": "ReactNode",
      "required": false,
      "description": "Content rendered inside the card body"
    }
  ]
}